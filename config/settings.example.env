APP_ENV=dev
MILVUS_URI=./runtime/vectorstores/milvus/papers.db
MILVUS_COLLECTION=synbio_papers
BGE_M3_MODEL_PATH=./models/BAAI/bge-m3

RETRIEVAL_SEARCH_LIMIT=30
RETRIEVAL_DENSE_LIMIT=30
RETRIEVAL_BM25_LIMIT=30
RETRIEVAL_RERANK_TOP_K=12
RETRIEVAL_FINAL_TOP_K=10
RETRIEVAL_EVIDENCE_NUMERIC_BONUS=0.08
RETRIEVAL_EVIDENCE_RESULT_BONUS=0.1
RETRIEVAL_EVIDENCE_DEFINITION_BONUS=0.06
RETRIEVAL_SECTION_RESULTS_BONUS=0.2
RETRIEVAL_SECTION_DISCUSSION_BONUS=0.15
RETRIEVAL_SECTION_ABSTRACT_BONUS=0.05
RETRIEVAL_NEIGHBOR_EXPANSION_ENABLED=true
RETRIEVAL_NEIGHBOR_WINDOW_SIZE=1
RETRIEVAL_NEIGHBOR_EXPANSION_MAX_CHUNKS=18

# 预留 QWEN 接口
QWEN_CHAT_API_BASE=
QWEN_CHAT_API_KEY=
QWEN_RERANK_API_BASE=
QWEN_RERANK_API_KEY=

# Round8 policy flags. Keep disabled for Round7-compatible behavior.
ROUND8_ENABLE_ROUND8_POLICY=false
ROUND8_DISABLE_COMPARISON_SINGLE_DOC_HARD_REFUSAL=false
ROUND8_ENABLE_CLAIM_FALLBACK=false
ROUND8_ENABLE_PARTIAL_ANSWER=false
ROUND8_ENABLE_ROUTE_SPECIFIC_THRESHOLDS=false
ROUND8_ENABLE_COMPARISON_PROMPT_V2=false
ROUND8_ENABLE_CITATION_EXPANSION=false
ROUND8_ENABLE_RAGAS_RETRY=false
# chat model defaults to qwen-plus in code
BGE_RERANKER_MODEL_PATH=./models/BAAI/bge-reranker-v2-m3
RERANKER_SERVICE_URL=
AUDIT_LOG_PATH=./runtime/logs/rag_audit.jsonl
SESSION_STORE_PATH=./runtime/logs/session_store.json
